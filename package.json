{
  "name": "bldc_console",
  "private": true,
  "version": "0.0.0",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev:electron": "tsc -p electron/tsconfig.json -w",
    "dev": "npm run build:electron && concurrently \"vite\" \"npm run dev:electron\" \"wait-on tcp:5173 && cross-env NODE_ENV=development electron . --no-sandbox --ozone-platform=x11\"",
    "build:electron": "tsc -p electron/tsconfig.json",
    "build": "tsc -b && vite build && npm run build:electron",
    "lint": "eslint .",
    "preview": "vite preview",
    "build:mac": "npm run build && electron-builder --mac",
    "build:win": "npm run build && electron-builder --win",
    "build:linux": "npm run build && electron-builder --linux",
    "build:all": "npm run build && electron-builder -mwl"
  },
  "build": {
    "extends": null,
    "appId": "com.bldc_console.app",
    "productName": "BLDC Console",
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "package.json"
    ],
    "directories": {
      "buildResources": "assets",
      "output": "release"
    },
    "mac": {
      "target": "dmg",
      "category": "public.app-category.developer-tools"
    },
    "win": {
      "target": "nsis"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Development"
    }
  },
  "dependencies": {
    "@base-ui/react": "^1.4.1",
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource-variable/public-sans": "^5.2.7",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "electron-is-dev": "^3.0.1",
    "embla-carousel-react": "^8.6.0",
    "lucide-react": "^1.14.0",
    "next-themes": "^0.4.6",
    "react": "^19.2.6",
    "react-day-picker": "^10.0.0",
    "react-dom": "^19.2.6",
    "react-resizable-panels": "^4.11.1",
    "react-router-dom": "^7.15.0",
    "recharts": "3.8.0",
    "shadcn": "^4.7.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.2.1",
    "tw-animate-css": "^1.4.0",
    "vaul": "^1.1.2"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.12.4",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.5.0",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^42.0.1",
    "electron-builder": "^26.8.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "postcss": "^8.5.14",
    "vite": "^8.0.12",
    "wait-on": "^9.0.10",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.1"
  }
}
